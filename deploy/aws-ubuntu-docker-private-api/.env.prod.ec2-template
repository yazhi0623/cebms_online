# 这是一份 AWS EC2 Ubuntu 第二版部署示例。
# 使用前请先复制为 .env.prod，再把带有示例值的字段改成你自己的真实值。

# 应用名称。
APP_NAME=CEBMS API

# 生产环境固定为 production。
APP_ENV=production

# 生产环境必须关闭调试。
APP_DEBUG=false

# API 前缀，保持默认。
API_V1_PREFIX=/api/v1

# PostgreSQL 容器名，Docker 内部通信固定为 postgres。
POSTGRES_SERVER=postgres

# PostgreSQL 端口。
POSTGRES_PORT=5432

# 数据库名称。
POSTGRES_DB=cebms

# 数据库用户名。
POSTGRES_USER=cebms_user

# 数据库密码，必须改成你自己的强密码。
POSTGRES_PASSWORD=ChangeThisToYourStrongDbPassword_2026

# JWT 密钥，必须改成你自己的超长随机字符串。
JWT_SECRET_KEY=ChangeThisToYourVeryLongRandomJwtSecret_2026

# JWT 算法，保持默认。
JWT_ALGORITHM=HS256

# Access Token 过期时间，单位分钟。
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# 生产建议关闭注册。
AUTH_REGISTRATION_ENABLED=false

# 开启登录失败限流。
AUTH_LOGIN_RATE_LIMIT_ENABLED=true

# 登录失败允许次数。
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=5

# 登录失败限流窗口，单位秒。
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# 前端 toast 时长。
TOAST_DURATION_MS=2400

# 每日 AI 分析次数限制。
DAILY_ANALYSIS_LIMIT=20

# 触发 AI 分析的最少记录数。
ANALYSIS_THRESHOLD=10

# 如果暂时不接真实模型，先保持 false。
ANALYSIS_LLM_ENABLED=false

# AI 输出最大长度。
ANALYSIS_MAX_LLM_OUTPUT_CHARS=300

# 模型配置文件路径，Docker 内部保持默认。
ANALYSIS_MODELS_PATH=/app/backend/config/models.json

# 千问 Key，不用真实 AI 时可留空。
QWEN_API_KEY=

# 千问接口地址。
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek Key，不用时可留空。
DEEPSEEK_API_KEY=

# DeepSeek 接口地址，不用时可留空。
DEEPSEEK_BASE_URL=

# DeepSeek 模型名。
DEEPSEEK_MODEL=deepseek-chat

# 这里填写你的 EC2 公网 IP 或域名。
# 例子：假设你的公网 IP 是 18.162.10.20
BACKEND_CORS_ORIGINS=http://18.162.10.20

# 这里填写允许访问后端的 Host。
# 如果你还没有域名，先填公网 IP。
BACKEND_TRUSTED_HOSTS=18.162.10.20

# 上传文件大小限制，单位 MB。
UPLOAD_MAX_FILE_SIZE_MB=20

# 安全响应头保持开启。
SECURE_RESPONSE_HEADERS_ENABLED=true
