# 复制自 deploy/aws-ubuntu-docker/.env.prod.example。
# 第二版部署不暴露 8000，但后端配置项本身保持一致。
APP_NAME=CEBMS API
APP_ENV=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cebms
POSTGRES_USER=cebms_user
POSTGRES_PASSWORD=please-change-this-db-password
JWT_SECRET_KEY=please-change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REGISTRATION_ENABLED=false
AUTH_LOGIN_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
TOAST_DURATION_MS=2400
DAILY_ANALYSIS_LIMIT=20
ANALYSIS_THRESHOLD=10
ANALYSIS_LLM_ENABLED=false
ANALYSIS_MAX_LLM_OUTPUT_CHARS=300
ANALYSIS_MODELS_PATH=/app/backend/config/models.json
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=deepseek-chat
BACKEND_CORS_ORIGINS=http://YOUR_SERVER_IP
BACKEND_TRUSTED_HOSTS=YOUR_SERVER_IP
UPLOAD_MAX_FILE_SIZE_MB=20
SECURE_RESPONSE_HEADERS_ENABLED=true
DAILY_ANALYSIS_LIMIT_WHEN_LLM_DISABLED=5
